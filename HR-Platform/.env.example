# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:root@localhost:5432/hr_platform

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_change_this_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Invite
INVITE_TOKEN_EXPIRES_DAYS=7
